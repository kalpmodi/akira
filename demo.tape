# Akira Demo - VHS Cassette
# Install vhs: brew install vhs  OR  go install github.com/charmbracelet/vhs@latest
# Generate GIF: vhs demo.tape

Output demo.gif

Set FontSize 14
Set Width 110
Set Height 38
Set Theme "Dracula"
Set Padding 20
Set Framerate 24
Set PlaybackSpeed 1.0

# Run the demo simulator
Type "bash demo/simulate.sh"
Enter

Sleep 30s
